rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /events/{eventId} {
      // Public event pages: anyone can read non-suspended events
      allow read: if resource.data.status == 'live' || resource.data.status == 'featured'
                  || (signedIn() && (resource.data.organizerId == request.auth.uid || isAdmin()));
      allow create: if signedIn() && request.resource.data.organizerId == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.organizerId == request.auth.uid || isAdmin());
    }

    match /rsvps/{rsvpId} {
      allow read: if signedIn() && (resource.data.attendeeId == request.auth.uid
        || get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid
        || isAdmin());
      allow create: if signedIn() && request.resource.data.attendeeId == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.attendeeId == request.auth.uid
        || get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid
        || isAdmin());
    }
  }
}
